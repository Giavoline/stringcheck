#include <stdio.h>

#include "numbers.h"

struct testcase
{
    const char *a;
    const long *b;
    const char **c;
    int expected;
};

int main(void)
{
    struct testcase tests[] =
    {
        {"hello","hello",0},
        {"Hello","Hello",0},
        {"7 test","test",1},
        {"27 test","test",1},
        {"green apples","green apples",0},
        {"37 spots","37 spots",1},
    };

    int failures = 0;

    for (size_t i = 0; i < sizeof(tests)/sizeof(tests[0]); i++)
    {
        int d = sc_parse_leading_number(tests[i].a,tests[i].b,tests[i].c);

        if (d != tests[i].expected)
        {
            printf("FAIL: \"%s\" \"%s\" -> %d (expected %d)\n",
                   tests[i].a,
                   tests[i].b,
                   d,
                   tests[i].expected);
            failures++;
        }
        else
        {
            printf("PASS: \"%s\" \"%s\" -> %d\n",
                   tests[i].a,
                   tests[i].b,
                   d);
        }
    }

    return failures != 0;
}
